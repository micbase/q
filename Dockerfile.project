FROM node:24-slim

RUN apt-get update && apt-get install -y git bash ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Install Go
RUN curl -fsSL https://go.dev/dl/go1.24.1.linux-amd64.tar.gz | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:/root/go/bin:${PATH}"

# Install air (Go live reload)
RUN GOBIN=/usr/local/bin go install github.com/air-verse/air@latest

RUN npm install -g @anthropic-ai/claude-code

RUN useradd -m -s /bin/bash -u 9999 claude

WORKDIR /workspace

CMD ["sleep", "infinity"]
