# MySQL (credentials are scrubbed from process.env after startup)
DB_HOST=192.168.1.x
DB_PORT=3306
DB_NAME=q
DB_USER=q
DB_PASSWORD=secret

# Projects — base directory for project working directories
# Each project gets ${PROJECTS_DIR}/${project.name} mounted as /workspace in its container
PROJECTS_DIR=/nas/projects

# App
NTFY_URL=https://ntfy.yourdomain.com/q
API_PORT=3200
POLL_INTERVAL_MS=5000
RETRY_DELAY_MS=60000
CONTAINER_IDLE_TIMEOUT_MS=600000
PROJECT_IMAGE=q-project
DOCKER_RUN_OPTIONS={"HostConfig":{"NetworkMode":"dev"}}

# Dry run mode — set to "true" to skip Docker and Claude entirely
DRY_RUN=false
